        "plt.plot(x_vals, y_vals, label=\"Regression Line\")\n",
        "plt.scatter(x1, y, label=\"Given Point\")\n",
        "plt.title(\"Linear Regression (Single Feature)\")\n",
        "plt.xlabel(\"x\")\n",
        "plt.ylabel(\"y\")\n",
        "plt.legend()\n",
        "plt.show()"
